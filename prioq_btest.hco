  "hvm": {
    "modules": {
        "__main__": {
            "file": "prioq_btest.hny",
            "lines": [
                "#black box test",
                "import prioq",
                "const NPRIO = 1",
                "const NPUT = 1",
                "const NGET = 1",
                "",
                "myq = prioq.PrioQ(NPRIO)",
                "",
                "def thread_put():",
                "    var priority = 0",
                "    var value = choose {\"a\", \"b\"}",
                "    print (\"invoke put\",  priority)",
                "    prioq.put(?myq, priority, value)",
                "    print (\"complete put\", priority)",
                "",
                "def thread_get():",
                "    print (\"invoke get\")",
                "    var res = prioq.get(?myq)",
                "    print (\"complete get\", res)",
                "",
                "i = 0",
                "while i < NPUT:",
                "    spawn thread_put()",
                "    i = i + 1",
                "i = 0",
                "while i < NGET:",
                "    spawn thread_get()",
                "    i = i + 1"
              ],
            "identifiers": {
                "res": "local-var",
                "NGET": "constant",
                "value": "local-var",
                "i": "global",
                "thread_get": "constant",
                "thread_put": "constant",
                "NPUT": "constant",
                "priority": "local-var",
                "this": "local-var",
                "___": "___",
                "NPRIO": "constant",
                "myq": "global",
                "prioq": "module"
              }
          },
        "prioq": {
            "file": "prioq.hny",
            "lines": [
                "#spec",
                "def PrioQ(n) returns init:",
                "    init = []",
                "    var i = 0",
                "    while i < n:",
                "        init[len init] = []",
                "        i = i + 1",
                "",
                "def put(pq, prio, v):",
                "    atomically:",
                "        (!pq)[prio][len (!pq)[prio]] = v",
                "",
                "def get(pq) returns r:",
                "    r = (False, None)",
                "    var i = 0",
                "    while (i < len (!pq)) and (r[0] == False):",
                "        atomically:",
                "            if (r[0] == False) and ((len (!pq)[i]) > 0):",
                "                r = (True, (!pq)[i][0])",
                "                del (!pq)[i][0]",
                "        i = i + 1",
                "",
                "# p = PrioQ(3)",
                "# put(?p, 0, \"a\")",
                "# put(?p, 1, \"b\")",
                "# put(?p, 2, \"c\")",
                "# print get(?p)",
                "# print get(?p)"
              ],
            "identifiers": {
                "PrioQ": "constant",
                "get": "constant",
                "pq": "local-const",
                "n": "local-const",
                "i": "local-var",
                "this": "local-var",
                "v": "local-const",
                "prio": "local-const",
                "put": "constant",
                "___": "___"
              }
          }
      },
