    "alloc": {
      "file": "/Users/adyamohanty/miniconda3/lib/python3.12/site-packages/harmony_model_checker/modules/alloc.hny",
      "lines": [
        "pool = {:}",
        "next = 0",
        "",
        "# builtin malloc \"alloc$malloc\"",
        "# TODO.  builtin malloc temporarily disabled",
        "def malloc(v) returns copy:",
        "    atomically:",
        "        pool[next] = v",
        "        copy = ?pool[next]",
        "        next += 1",
        "",
        "# Commented out code tests for bad frees, but can lead to data races",
        "def free(r):",
        "    atomically:",
        "       # let poolcopy = pool:",
        "            del !r",
        "       #    assert poolcopy != pool, .bad_free",
        "",
        "def leak_check():",
        "    assert pool == {:}, .alloc_leak"
      ],
