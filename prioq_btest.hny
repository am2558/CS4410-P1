#black box test
import prioq
const NPRIO = 1
const NPUT = 1
const NGET = 1

myq = prioq.PrioQ(NPRIO)

def thread_put():
    print("invoke put", 0)
    prioq.put(?myq, 0, "a")
    print("complete put")

def thread_get():
    var res = prioq.get(?myq)
    print("complete get", res)

i = 0
while i < NPUT:
    spawn thread_put()
    i = i + 1
i = 0
while i < NGET:
    spawn thread_get()
    i = i + 1